; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Shattered"
config/description="Fixed-World Roguelike RPG"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameState="*res://scripts/core/GameState.gd"
EventBus="*res://scripts/core/EventBus.gd"
WorldManager="*res://scripts/core/WorldManager.gd"
LocationRegistry="*res://scripts/world/LocationRegistry.gd"
WorldSaveManager="*res://scripts/core/WorldSaveManager.gd"
TurnManager="*res://scripts/core/TurnManager.gd"
SaveManager="*res://scripts/core/SaveManager.gd"
CombatManager="*res://scripts/combat/CombatManager.gd"
ItemDB="*res://scripts/items/ItemDB.gd"
Inventory="*res://scripts/items/Inventory.gd"
Equipment="*res://scripts/items/Equipment.gd"
LevelSystem="*res://scripts/core/LevelSystem.gd"
DialogueManager="*res://scripts/dialogue/DialogueManager.gd"
QuestManager="*res://scripts/dialogue/QuestManager.gd"
SettingsManager="*res://scripts/core/SettingsManager.gd"
ScreenFade="*res://scripts/core/ScreenFade.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720

